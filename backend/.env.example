# Copy to .env and fill in real values: cp .env.example .env

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/pacetrack?retryWrites=true&w=majority

# JWT (use long random strings in production)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=15m
REFRESH_SECRET=change-me-to-another-long-random-string
REFRESH_EXPIRES_IN=7d

# AWS S3 for GPX uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=pacetrack-gpx
AWS_REGION=us-east-1

# Server
PORT=8000
